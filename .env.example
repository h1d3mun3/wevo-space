# Environment Configuration Example
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================

# Option 1: Use DATABASE_URL (Heroku, Railway, etc.)
# DATABASE_URL=postgres://username:password@localhost:5432/wevospace

# For docker-compose: set DB_PASSWORD in a .env file at the project root
# DB_PASSWORD=your-password-here

# Option 2: Use individual environment variables
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=vapor
DATABASE_PASSWORD=password
DATABASE_NAME=wevospace

# ============================================
# Application Configuration
# ============================================

# Application environment: development, production
# ENVIRONMENT=development

# Log level: trace, debug, info, notice, warning, error, critical
# LOG_LEVEL=info

# ============================================
# Multi-Node Sync (optional)
# ============================================

# Comma-separated list of peer node URLs. Leave blank for single-node deployments.
# PEER_NODES=https://node-b.example.com,https://node-c.example.com

# Shared secret for inter-node authentication. Must match across all nodes.
# Generate with: openssl rand -hex 32
# SYNC_SECRET=change-this-to-a-strong-random-secret

# How often (in seconds) this node pulls proposes from peers. Default: 60
# SYNC_INTERVAL_SECONDS=60

# ============================================
# Security Configuration
# ============================================

# Rate limiting
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Request size limit
# MAX_REQUEST_SIZE=1mb
