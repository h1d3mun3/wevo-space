# Environment Configuration Example
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================

# Option 1: Use DATABASE_URL (Heroku, Railway, etc.)
# DATABASE_URL=postgres://username:password@localhost:5432/wevospace

# For docker-compose: set DB_PASSWORD in a .env file at the project root
# DB_PASSWORD=your-password-here

# Option 2: Use individual environment variables
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=vapor
DATABASE_PASSWORD=password
DATABASE_NAME=wevospace

# ============================================
# Application Configuration
# ============================================

# Application environment: development, production
# ENVIRONMENT=development

# Log level: trace, debug, info, notice, warning, error, critical
# LOG_LEVEL=info

# ============================================
# Security Configuration
# ============================================

# Rate limiting
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Request size limit
# MAX_REQUEST_SIZE=1mb
